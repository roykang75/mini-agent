# mini-agent — environment variables
# Copy to .env.local and fill in real values. Do NOT commit .env.local.

# ─── LLM provider ──────────────────────────────────────────
# Anthropic API key. Required when LLM_PROVIDER=anthropic (default).
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional. Defaults to "anthropic". Switch provider here once adapters are added.
# LLM_PROVIDER=anthropic

# Optional. Defaults to "claude-sonnet-4-5". Any Anthropic model ID.
# LLM_MODEL=claude-sonnet-4-5

# ─── Vault (필수 — Hashicorp KV v2, AppRole 인증) ──────────
# runtime singleton 은 첫 vault 호출 시 이 env 들로 HashicorpVaultBackend 를
# 구성. 누락되면 명확한 startup 에러. 외부 네트워크에서 접근 가능한 vault
# 서버 (tunnel 등) 구축은 별도 작업.
VAULT_ADDR=http://192.168.1.218:8200
VAULT_ROLE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
VAULT_SECRET_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
VAULT_KV_MOUNT=secret
VAULT_KV_PREFIX=cia
# Enterprise only. Leave unset for OSS.
# VAULT_NAMESPACE=

# ─── Agent Memory (M1 Phase 8 T8.1) ────────────────────────
# AgentEvent JSONL 을 append 할 agent-memory 레포 로컬 경로.
# 설정되면 src/lib/memory/raw.ts 가 raw/YYYY/MM/DD/NNNN.jsonl 에 기록.
# 미설정 시 raw append 는 no-op 으로 skip (경고 한 번 후 조용히).
# AGENT_MEMORY_DIR=/Users/you/Workspace/agent/agent-memory

# ─── Auto consolidate (ADR-007) ────────────────────────────
# "on" 이면 매 receive() 종료 시 scripts/consolidate.ts 를 fire-and-forget
# 으로 spawn → raw jsonl 이 자동으로 episode v2 로 변환. Sonnet 호출 비용
# 세션당 ~$0.02. default off — smoke 테스트가 tmp AGENT_MEMORY_DIR 로
# inadvertent 호출 방지. 실 dev 서버에선 켜는 것을 권장.
# AUTO_CONSOLIDATE=on

# ─── Post-goal hook (ADR-007 P3 자동화) ────────────────────
# "on" 이면 goal 이 completed | paused | aborted 로 전이할 때
# scripts/post-goal-hook.ts 가 spawn → 최근 N 개 episode 에 대해 Opus
# grade-real-session 실행. goal 당 ~$0.05. default off — 명시 opt-in.
# AUTO_CONSOLIDATE 와 같이 켜야 유용 (episode 없으면 grade 할 대상도 없음).
# POST_GOAL_HOOK=on
# POST_GOAL_HOOK_WAIT_MS=30000
# POST_GOAL_HOOK_N=3

# ─── Retry cap (M1 Phase 6) ────────────────────────────────
# 같은 (tool name, args) 를 이만큼 반복 시도하면 executeSkill 을 skip 하고
# 구조화된 retry_limit_exceeded 에러를 LLM 에 반환. 기본 3.
# RETRY_LIMIT=3

# ─── Working memory store (ADR-005) ────────────────────────
# AgentInstance 의 working memory 를 persistent 하게 저장. sid 쿠키 수명
# (24h) 동안 유지. HMR / 재시작 후에도 summonAgent(sid) 가 hydrate 해
# 같은 agent 가 깨어남. Redis native TTL 이 자연 cleanup.
REDIS_URL=redis://192.168.1.218:6379
# 강제 in-memory (테스트 / CI). 미설정 시 REDIS_URL 있으면 Redis 사용.
# AGENT_STATE_BACKEND=memory

# ─── Advisor (ADR-004) ─────────────────────────────────────
# ask_advisor skill 이 호출하는 상위 모델 (기본 Opus). HIL 없이 자동 실행.
# API key 미지정 시 ANTHROPIC_API_KEY 를 재사용.
# ADVISOR_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# ADVISOR_MODEL=claude-opus-4-7
# ADVISOR_MAX_TOKENS=4096
# 세션당 advisor 호출 상한. 미설정 = 무제한.
# ADVISOR_CALL_LIMIT=5

# ─── Night's Watch observability ───────────────────────────
# "on" 이면 receive / resume 모든 턴이 NW 로 송출 (250ms timer + 32 batch
# flush, fire-and-forget). 기본 off — 명시적으로 켜야 trace 가 NW 에 적재.
# NW dev 서버가 NW_BASE_URL 에 안 떠 있으면 client 가 .observer-outbox/
# 로 적재했다가 30초 reaper 로 재발송 (안전망).
# NW_ENABLED=on
# NW_BASE_URL=http://localhost:3001
# NW_INGEST_TOKEN=